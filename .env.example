# Django
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,qalbconverfy.in,api.qalbconverfy.in
DJANGO_SETTINGS_MODULE=config.settings.development

# PostgreSQL (Primary DB — relational/financial data)
DB_NAME=qabifly_db
DB_USER=qabifly_user
DB_PASSWORD=strongpassword
DB_HOST=db
DB_PORT=5432

# MongoDB (Secondary DB — IoT, GIS, logs, chat, media metadata)
MONGO_DB_NAME=qabifly_mongo
MONGO_USER=mongo_admin
MONGO_PASSWORD=mongostrongpassword
MONGO_HOST=mongodb
MONGO_PORT=27017

# Redis (OTP cache, sessions, Celery broker, WebSocket layer)
REDIS_URL=redis://redis:6379/0

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — Self-hosted SMTP via your domain (qalbconverfy.in)
# For development: use Postfix or any SMTP relay you control
EMAIL_HOST=mail.qalbconverfy.in
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@qalbconverfy.in
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=QabiFly <noreply@qalbconverfy.in>

# Phone OTP (Fast2SMS — only for optional phone verification)
FAST2SMS_API_KEY=your-fast2sms-api-key

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret

# File Storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=qabifly-media
AWS_S3_ENDPOINT_URL=http://localhost:9000

# Platform Business Rules
PLATFORM_COMMISSION_PERCENT=5
SHOPKEEPER_PERCENT=92
DELIVERY_BOY_PERCENT=3
MAX_UDHAAR_LIMIT=20000

# OTP Settings
EMAIL_OTP_EXPIRY_MINUTES=10
PHONE_OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

